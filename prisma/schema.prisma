generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String   @id @default(cuid())
  clerkOrgId     String   @unique
  businessName   String
  kycStatus       String   @default("pending") // pending | approved | rejected
  liveRequestedAt DateTime? // merchant requested go-live; awaiting admin approval
  liveApprovedAt  DateTime?
  liveApprovedBy  String?
  environment     String   @default("sandbox")
  createdAt       DateTime @default(now())

  merchant         Merchant?
  memberships      Membership[]
  apiKeys          ApiKey[]
  transactions     Transaction[]
  darajaCredential OrganizationDarajaCredential?
  kycDocuments     KycDocument[]
  auditLogs        AuditLog[]
  subscription     Subscription?
  payouts          Payout[]
  refunds          Refund[]
  accountBalances  AccountBalanceSnapshot[]
  darajaCommands   DarajaCommand[]
  paymentLinks     PaymentLink[]
}

// A shareable, PaySwift-hosted payment link — the no-code way for a merchant to
// collect an M-Pesa payment with zero API integration. The public hosted
// checkout lives at /pay/[slug]; payments made through it attribute back via
// Transaction.paymentLinkId. A live link requires the org's liveApprovedAt (the
// same admin-gated go-live check as the API). findActiveLinkBySlug() is the one
// deliberately un-scoped lookup (documented, like the C2B shortcode lookup) that
// powers the public page.
model PaymentLink {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  merchantId     String
  merchant       Merchant      @relation(fields: [merchantId], references: [id])
  slug           String        @unique // public, URL-safe id used in /pay/[slug]
  title          String
  description    String?
  amountType     String        @default("fixed") // fixed | customer_set
  amount         Int?          // KES minor units; required when amountType = fixed
  active         Boolean       @default(true)
  environment    String        @default("sandbox")
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  transactions   Transaction[]

  @@index([organizationId, createdAt(sort: Desc)])
}

// Ledger of initiator-authenticated Daraja commands (Transaction Status, Account
// Balance, Reversal). Each async result callback correlates back by the unique
// originatorConversationId Daraja returned at initiation — a single home for
// that correlation instead of per-model fields.
model DarajaCommand {
  id                       String       @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  type                     String       // transaction_status | account_balance | reversal
  environment              String       @default("sandbox")
  originatorConversationId String       @unique
  conversationId           String?
  targetReceipt            String?      // the M-Pesa receipt being queried/reversed
  targetPayoutId           String?      // the Payout being reversed, if any
  status                   String       @default("pending") // pending | completed | failed
  resultCode               Int?
  resultDesc               String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([organizationId, createdAt(sort: Desc)])
}

// Latest-and-historical M-Pesa account balance readings per org, populated by
// the Account Balance result callback. Used for ops alerting ("balance low,
// payouts may fail") and surfaced in the admin console.
model AccountBalanceSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  environment    String       @default("sandbox")
  balanceRaw     String       // Daraja's raw AccountBalance string
  workingBalance Int?         // parsed working-account balance (KES), best-effort
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
}

// Placeholder pricing seeded by lib/repositories/billing.ts's
// ensurePlansSeeded() — NOT a confirmed product/pricing decision, flagged
// explicitly in that module for a real decision before launch.
model Plan {
  id            String         @id @default(cuid())
  name          String         @unique // Starter | Growth | Scale
  monthlyFee    Int            // KES, minor units (whole shillings, matching Transaction.amount's convention)
  txFeeBps      Int            // basis points of transaction volume
  txCapMonthly  Int?           // null = uncapped
  subscriptions Subscription[]
}

model Subscription {
  id               String        @id @default(cuid())
  organizationId   String        @unique
  organization     Organization  @relation(fields: [organizationId], references: [id])
  planId           String
  plan             Plan          @relation(fields: [planId], references: [id])
  status           String        @default("active") // active | past_due | suspended | canceled
  currentPeriodEnd DateTime
  invoices         Invoice[]
  usageRecords     UsageRecord[]
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  amount         Int
  status         String       @default("pending") // pending | paid | failed
  pdfUrl         String?
  issuedAt       DateTime     @default(now())
}

model UsageRecord {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  periodStart    DateTime
  periodEnd      DateTime
  txCount        Int
  txVolume       Int

  @@index([subscriptionId])
}

// Deliberately NOT related to Organization — an admin must never accidentally
// inherit tenant-scoped permissions through this table. Auth is gated via
// lib/admin-auth.ts's requireAdmin(), never lib/rbac.ts's requireRole().
model AdminUser {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  role        String   @default("support") // support | superadmin
  createdAt   DateTime @default(now())
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  actorId        String        // Clerk user ID (member action) or AdminUser's clerkUserId (admin action)
  action         String        // e.g. "api_key.created", "org.live_credential_set", "admin.impersonated"
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
}

model KycDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String       // id | business_registration | kra_pin
  storageKey     String       // R2 object key — private; view via lib/storage.ts's signed URL
  reviewStatus   String       @default("pending") // pending | approved | rejected
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model OrganizationDarajaCredential {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Sandbox — pooled/PaySwift-managed by default (master plan Section 16.2);
  // an org may optionally override with its own sandbox app.
  consumerKeyEncrypted    String
  consumerSecretEncrypted String
  shortcode               String
  passkeyEncrypted        String
  callbackUrl             String
  isPooledSandbox         Boolean @default(true)

  // Live — always the organization's own, never pooled (Model B). Null until
  // the org completes onboarding's Payment Setup step for live mode.
  consumerKeyLiveEncrypted    String?
  consumerSecretLiveEncrypted String?
  shortcodeLive               String?
  passkeyLiveEncrypted        String?
  callbackUrlLive              String?

  // B2C / Reversal / Account Balance / Transaction Status initiator credentials.
  // initiatorName is plaintext (a username); the initiator password is AES-encrypted
  // at rest and RSA-encrypted with Safaricom's public cert at call time to produce
  // the Daraja SecurityCredential (see lib/daraja-security-credential.ts). Null
  // until the org supplies them in Payment Setup.
  initiatorName             String?
  initiatorPasswordEncrypted String?
  initiatorNameLive         String?
  initiatorPasswordLiveEncrypted String?

  updatedAt DateTime @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clerkUserId    String
  role           String       // owner | admin | developer | finance
  createdAt      DateTime     @default(now())

  @@unique([organizationId, clerkUserId])
  @@index([clerkUserId])
}

model Merchant {
  id                      String        @id @default(cuid())
  clerkUserId             String        @unique
  organizationId          String        @unique
  organization            Organization  @relation(fields: [organizationId], references: [id])
  businessName            String
  webhookUrl              String?
  environment             String        @default("sandbox")
  createdAt               DateTime      @default(now())
  shopifyAdminAccessToken String?
  shopifyShopDomain       String?
  shopifyWebhookSecret    String?
  webhookSecret           String?       @unique
  apiKeys                 ApiKey[]
  transactions            Transaction[]
  payouts                 Payout[]
  refunds                 Refund[]
  paymentLinks            PaymentLink[]
}

model ApiKey {
  id             String        @id @default(cuid())
  merchantId     String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  scope          String        @default("read_write") // read_only | read_write
  createdAt      DateTime      @default(now())
  revoked        Boolean       @default(false)
  keyHash        String        @unique
  keyPrefix      String
  merchant       Merchant      @relation(fields: [merchantId], references: [id])

  @@index([organizationId])
}

model Transaction {
  id                String            @id @default(cuid())
  merchantId        String
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id])
  amount            Int
  phone             String
  orderReference    String?
  status            String            @default("pending")
  checkoutRequestId String?           @unique
  mpesaReceipt      String?
  resultCode        Int?
  resultDesc        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  environment       String            @default("sandbox")
  source            String            @default("api")
  paymentLinkId     String?
  paymentLink       PaymentLink?      @relation(fields: [paymentLinkId], references: [id])
  merchant          Merchant          @relation(fields: [merchantId], references: [id])
  webhookDeliveries WebhookDelivery[]

  @@index([merchantId, createdAt(sort: Desc)])
  @@index([merchantId, status])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([paymentLinkId])
  refunds           Refund[]
}

// B2C disbursement (business → customer). Status is written ONLY by the B2C
// result callback (app/api/mpesa/b2c/result) — the sole writer of terminal
// payout status, mirroring the STK callback's authority over transactions.
model Payout {
  id                       String       @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  merchantId               String
  merchant                 Merchant     @relation(fields: [merchantId], references: [id])
  amount                   Int
  phone                    String
  commandId                String       @default("BusinessPayment") // BusinessPayment | SalaryPayment | PromotionPayment
  remarks                  String?
  occasion                 String?
  status                   String       @default("pending") // pending | completed | failed
  conversationId           String?
  originatorConversationId String?      @unique // Daraja's async-callback correlation key
  mpesaReceipt             String?
  resultCode               Int?
  resultDesc               String?
  environment              String       @default("sandbox")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  webhookDeliveries        WebhookDelivery[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
}

// Refund of a specific collected Transaction, executed via B2C back to the
// customer. Terminal status is written ONLY by the B2C result callback.
model Refund {
  id                       String       @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  merchantId               String
  merchant                 Merchant     @relation(fields: [merchantId], references: [id])
  transactionId            String
  transaction              Transaction  @relation(fields: [transactionId], references: [id])
  amount                   Int
  phone                    String
  reason                   String?
  status                   String       @default("pending") // pending | completed | failed
  conversationId           String?
  originatorConversationId String?      @unique
  mpesaReceipt             String?
  resultCode               Int?
  resultDesc               String?
  environment              String       @default("sandbox")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  webhookDeliveries        WebhookDelivery[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([transactionId])
}

// Reconciliation findings surfaced by the nightly ledger job — records whose
// Daraja callback never resolved them (a pending payout/transaction/command
// stuck past its expected window). Surfaced in the admin console for human
// review; we NEVER auto-flip a record to failed here (guardrail #4). Unique on
// (resourceType, resourceId) so re-running the job doesn't duplicate.
model ReconciliationMismatch {
  id             String    @id @default(cuid())
  organizationId String?
  resourceType   String    // transaction | payout | daraja_command
  resourceId     String
  reason         String
  status         String    @default("open") // open | resolved | ignored
  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?

  @@unique([resourceType, resourceId])
  @@index([status, detectedAt(sort: Desc)])
}

// Durable idempotency store — the Postgres fallback behind the Upstash Redis
// fast path (lib/idempotency.ts). Guarantees cache-and-replay survives a Redis
// outage/eviction. Keyed by "${organizationId}:${idempotencyKey}".
model IdempotencyRecord {
  id             String   @id @default(cuid())
  key            String   @unique
  organizationId String
  status         Int
  responseData   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

// A single WebhookDelivery is linked to exactly one of transaction/payout/refund
// (enforced in application code). transactionId is nullable as of the polymorphic
// migration so payout/refund events can be recorded the same way.
model WebhookDelivery {
  id            String       @id @default(cuid())
  transactionId String?
  payoutId      String?
  refundId      String?
  url           String
  payload       Json
  statusCode    Int?
  success       Boolean      @default(false)
  attempt       Int          @default(1)
  createdAt     DateTime     @default(now())
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  payout        Payout?      @relation(fields: [payoutId], references: [id])
  refund        Refund?      @relation(fields: [refundId], references: [id])

  @@index([transactionId])
  @@index([payoutId])
  @@index([refundId])
}

model DarajaToken {
  id          String   @id @default("singleton")
  accessToken String
  expiresAt   DateTime
}
